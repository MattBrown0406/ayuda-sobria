# Server-only registration email configuration (Cloudflare/Lovable secrets)
RESEND_API_KEY=
REGISTRATION_FROM_EMAIL="AyudaSobria <registro@ayudasobria.com>"
REGISTRATION_TO_EMAIL=matt@soberhelpline.com

# Cloudflare Turnstile: public site key at build time, secret key server-side only
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# AyudaSobria La Sobremesa Zoom lifecycle (all server-side; never prefix with VITE_)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_USER_ID=
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_AUTOMATION_SECRET=

# Optional email-provider fallback used by the server-side Zoom mailer
LOVABLE_API_KEY=
